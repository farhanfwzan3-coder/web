CREATE DATABASE aspirasi_pengaduan;
USE aspirasi_pengaduan;

-- TABEL USERS
CREATE TABLE users (
    id INT AUTO_INCREMENT PRIMARY KEY,
    nama VARCHAR(100),
    username VARCHAR(50),
    role ENUM('siswa','admin')
);

