-- TABEL LAPORAN
CREATE TABLE laporan (
    id INT AUTO_INCREMENT PRIMARY KEY,
    user_id INT,
    judul VARCHAR(255),
    isi TEXT,
    foto VARCHAR(255),
    status VARCHAR(50) DEFAULT 'Menunggu',
    tanggal TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- TABEL TANGGAPAN
CREATE TABLE tanggapan (
    id INT AUTO_INCREMENT PRIMARY KEY,
    laporan_id INT,
    isi TEXT,
    tanggal TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);
